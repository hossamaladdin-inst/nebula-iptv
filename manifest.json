{
  "manifest_version": 3,
  "name": "Nebula IPTV – Xtream Player",
  "version": "1.0.0",
  "description": "Browse and play IPTV Xtream Code streams with category browsing, volume, seek, and FFW controls.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["player.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
